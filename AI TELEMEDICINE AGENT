from dataclasses import dataclass
from typing import List, Dict
import random

# ==========================================================
# AI TELEMEDICINE AGENT
# ==========================================================

@dataclass
class Patient:
    name: str
    age: int
    gender: str
    symptoms: List[str]
    duration: int
    severity: str
    conditions: str


class TelemedicineAgent:

    def __init__(self):

        self.patient_history = []

        self.knowledge_base = {

            ("fever", "cough"): {
                "condition": "Common Flu",
                "medicine": "Paracetamol + Cough Syrup",
                "doctor": "General Physician"
            },

            ("headache", "blurred vision"): {
                "condition": "Migraine",
                "medicine": "Ibuprofen",
                "doctor": "Neurologist"
            },

            ("stomach pain", "nausea"): {
                "condition": "Gastritis",
                "medicine": "Antacid",
                "doctor": "Gastroenterologist"
            },

            ("chest pain", "shortness of breath"): {
                "condition": "Cardiac Risk",
                "medicine": "Immediate Medical Evaluation",
                "doctor": "Cardiologist"
            },

            ("skin rash", "itching"): {
                "condition": "Skin Allergy",
                "medicine": "Antihistamine",
                "doctor": "Dermatologist"
            }
        }

    # ======================================================
    # RULE-BASED DIAGNOSIS
    # ======================================================

    def diagnose(self, symptoms):

        symptom_set = set(symptoms)

        for rule, result in self.knowledge_base.items():

            if set(rule).issubset(symptom_set):
                return result

        return {
            "condition": "General Health Issue",
            "medicine": "Consult Doctor",
            "doctor": "General Physician"
        }

    # ======================================================
    # RISK ASSESSMENT
    # ======================================================

    def calculate_risk(self, severity, duration):

        score = 0

        if severity.lower() == "mild":
            score += 20

        elif severity.lower() == "moderate":
            score += 50

        elif severity.lower() == "severe":
            score += 80

        if duration > 7:
            score += 20

        return min(score, 100)

    # ======================================================
    # PROBABILITY ESTIMATION
    # ======================================================

    def probability_estimation(self, risk_score):

        probability = risk_score * random.uniform(0.8, 1.0)

        return round(probability, 2)

    # ======================================================
    # SPECIALIST RECOMMENDATION
    # ======================================================

    def specialist_recommendation(self, condition):

        specialists = {

            "Common Flu": "General Physician",
            "Migraine": "Neurologist",
            "Gastritis": "Gastroenterologist",
            "Cardiac Risk": "Cardiologist",
            "Skin Allergy": "Dermatologist"
        }

        return specialists.get(
            condition,
            "General Physician"
        )

    # ======================================================
    # PATIENT REPORT
    # ======================================================

    def generate_report(self, patient):

        diagnosis = self.diagnose(patient.symptoms)

        risk_score = self.calculate_risk(
            patient.severity,
            patient.duration
        )

        probability = self.probability_estimation(
            risk_score
        )

        specialist = self.specialist_recommendation(
            diagnosis["condition"]
        )

        report = {

            "Patient Name": patient.name,
            "Age": patient.age,
            "Gender": patient.gender,
            "Condition": diagnosis["condition"],
            "Medicine": diagnosis["medicine"],
            "Doctor": specialist,
            "Risk Score": risk_score,
            "Probability": probability
        }

        self.patient_history.append(report)

        return report

    # ======================================================
    # DISPLAY HISTORY
    # ======================================================

    def show_history(self):

        if not self.patient_history:
            print("\nNo records found.")
            return

        print("\n========== PATIENT HISTORY ==========")

        for index, record in enumerate(
            self.patient_history,
            start=1
        ):

            print(f"\nRecord {index}")

            for key, value in record.items():
                print(f"{key}: {value}")

    # ======================================================
    # KNOWLEDGE BASE DISPLAY
    # ======================================================

    def display_rules(self):

        print("\n========== KNOWLEDGE BASE ==========")

        for symptoms, result in self.knowledge_base.items():

            print(
                f"\nSymptoms: {symptoms}"
            )

            print(
                f"Condition: {result['condition']}"
            )

            print(
                f"Doctor: {result['doctor']}"
            )

# ==========================================================
# MAIN SYSTEM
# ==========================================================

def main():

    agent = TelemedicineAgent()

    while True:

        print("\n====================================")
        print("      AI TELEMEDICINE AGENT")
        print("====================================")

        print("1. Register Patient")
        print("2. View Patient History")
        print("3. View Knowledge Base")
        print("4. Exit")

        choice = input("\nEnter Choice: ")

        # --------------------------------------------------

        if choice == "1":

            print("\nEnter Patient Details")

            name = input("Name: ")

            age = int(input("Age: "))

            gender = input("Gender: ")

            symptom_input = input(
                "Symptoms (comma separated): "
            )

            symptoms = [
                s.strip().lower()
                for s in symptom_input.split(",")
            ]

            duration = int(
                input("Duration (days): ")
            )

            severity = input(
                "Severity (Mild/Moderate/Severe): "
            )

            conditions = input(
                "Existing Conditions: "
            )

            patient = Patient(
                name,
                age,
                gender,
                symptoms,
                duration,
                severity,
                conditions
            )

            report = agent.generate_report(
                patient
            )

            print("\n========== AI REPORT ==========")

            for key, value in report.items():
                print(f"{key}: {value}")

            print("\nRecommendation:")

            if report["Risk Score"] >= 80:
                print(
                    "Immediate Hospital Visit Recommended"
                )

            elif report["Risk Score"] >= 50:
                print(
                    "Consult Specialist Soon"
                )

            else:
                print(
                    "Monitor Symptoms and Rest"
                )

        # --------------------------------------------------

        elif choice == "2":

            agent.show_history()

        # --------------------------------------------------

        elif choice == "3":

            agent.display_rules()

        # --------------------------------------------------

        elif choice == "4":

            print(
                "\nThank you for using AI Telemedicine Agent."
            )

            break

        # --------------------------------------------------

        else:

            print(
                "\nInvalid Choice. Try Again."
            )


if __name__ == "__main__":
    main()
